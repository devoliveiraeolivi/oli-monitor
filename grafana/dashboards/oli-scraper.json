    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Hora" },
            "properties": [{ "id": "custom.width", "value": 140 }]
          },
          {
            "matcher": { "id": "byName", "options": "Job ID" },
            "properties": [{ "id": "custom.width", "value": 280 }]
          },
          {
            "matcher": { "id": "byName", "options": "Processo" },
            "properties": [{ "id": "custom.width", "value": 210 }]
          },
          {
            "matcher": { "id": "byName", "options": "Críticos" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 0.5 },
                    { "color": "green", "value": 1 }
                  ]
                }
              },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Seções" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 0.5 },
                    { "color": "green", "value": 0.8 }
                  ]
                }
              },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "PDF" },
            "properties": [
              { "id": "custom.width", "value": 70 },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "uploaded": { "text": "OK", "color": "green" } } },
                { "type": "value", "options": { "falhou": { "text": "FALHOU", "color": "red" } } },
                { "type": "value", "options": { "indisponivel": { "text": "N/D", "color": "yellow" } } },
                { "type": "value", "options": { "nao_solicitado": { "text": "-", "color": "text" } } }
              ]}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Warns" },
            "properties": [
              { "id": "custom.width", "value": 60 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 1 },
                    { "color": "red", "value": 5 }
                  ]
                }
              },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
