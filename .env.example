# ═══════════════════════════════════════════════════════════════
# oli-monitor — env vars
# Copie para .env e preencha os valores.
# ═══════════════════════════════════════════════════════════════

# Grafana
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=

# Loki basic auth (para Alloy remoto)
# Gere com: htpasswd -nB loki-agent
# Formato: user:hash (escape $ → $$ no compose)
LOKI_BASIC_AUTH_USERS=

# Versões (opcional)
# LOKI_VERSION=3.6.7
# GRAFANA_VERSION=12.4.0
# ALLOY_VERSION=v1.13.2
