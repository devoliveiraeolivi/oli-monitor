      "title": "Qualidade por Job",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"worker\"} |= \"job_completed\" | json | q_criticos != \"\"",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": { "source": "labels", "format": "kvp" }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "^(Time|job_id|numero_processo|q_criticos|q_secoes|q_pdf|q_warnings|q_ausentes|q_secoes_vazias)$"
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "indexByName": {
              "Time": 0,
              "job_id": 1,
              "numero_processo": 2,
              "q_criticos": 3,
              "q_secoes": 4,
              "q_pdf": 5,
